HOST=0.0.0.0
PORT=8081
LOG_LEVEL=INFO
LOG_FORMAT=json
SWGI_MODE=production
SWGI_ORG_ID=org-prod
SWGI_COMMAND_CENTER_ID=cc-prod-001
COMMAND_CENTER_URL=http://localhost:8081
POLICY_PATH=./data/input/policy.json
SIGNING_KEY_PATH=./data/input/signing_key_ed25519.pem
DATABASE_URL=postgresql://swgi:swgi@localhost:5432/swgi_command_center
DB_CONNECT_TIMEOUT_SECONDS=5
RUN_DB_MIGRATIONS=true
RATE_LIMIT_PER_MINUTE=120
ADMIN_API_TOKEN=replace-admin-token
VIEWER_API_TOKEN=replace-viewer-token
API_KEY_HASH_SECRET=replace-with-32-plus-byte-random-secret
METRICS_ENABLED=true
