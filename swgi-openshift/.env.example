SWGI_MODE=production
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
LOG_FORMAT=json

SWGI_ORG_ID=org-prod
SWGI_NODE_ID=fen-ocp-001
POLICY_PATH=data/input/policy.json
SIGNING_KEY_PATH=data/input/signing_key_ed25519.pem

RECEIPT_STORE_BACKEND=sqlite
RECEIPT_DB_PATH=/tmp/swgi/receipts.db

DATABASE_URL=
DB_CONNECT_TIMEOUT_SECONDS=5
RUN_DB_MIGRATIONS=true

ADMIN_API_TOKEN=change-admin-token
VIEWER_API_TOKEN=change-viewer-token

TLS_ENABLED=false
METRICS_ENABLED=true
